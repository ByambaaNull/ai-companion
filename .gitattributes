# Normalize line endings across Windows / macOS / Linux checkouts.
* text=auto

# Shell scripts must stay LF or they fail with "bad interpreter" on macOS/Linux.
*.sh text eol=lf

# Windows-only scripts stay CRLF.
*.bat text eol=crlf
*.ps1 text eol=crlf

# Treat known binaries as binary (no EOL munging) — kept out of the repo by
# .gitignore, but guard against accidental adds.
*.pth binary
*.index binary
*.onnx binary
*.png binary
*.jpg binary
*.ico binary
