# =============================================================================
# AI Companion — .gitignore
# Keep the repo to source + config only. Models, build output, user data,
# secrets and caches are generated locally and must never be committed.
# =============================================================================

# ─── Secrets — NEVER commit ──────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# ─── Virtual environments ────────────────────────────────────────────────────
venv/
.venv/
env/

# ─── PyInstaller / build output ──────────────────────────────────────────────
build/
build_pyi/
dist/
.prebuild_backup/
*.spec.bak
# Bundled CLI tools (ffmpeg/mpv) if dropped at the source root for a dev run.
/bin/

# ─── Large model binaries (downloaded / placed locally) ──────────────────────
# NOTE: .gitignore has no inline comments — keep patterns on their own lines.
models/
piper/
# *.pth  = RVC voice model (e.g. assistant.pth);  *.index = its feature index
*.pth
*.index
*.onnx
*.bin
*.ckpt

# ─── User data, caches & runtime state (generated by the app) ────────────────
# Ignore everything inside data/ but keep the folder via .gitkeep. (Must be
# data/* — not data/ — or the .gitkeep negation can't re-include the file.)
data/*
!data/.gitkeep
backups/

# ─── Logs & temp ─────────────────────────────────────────────────────────────
*.log
*.log.*
*.tmp

# ─── Editor / OS cruft ───────────────────────────────────────────────────────
.vscode/
.idea/
.claude/
.DS_Store
Thumbs.db
desktop.ini
