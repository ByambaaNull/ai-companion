# ─── AI Companion secrets ─────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your own tokens. The .env file is
# gitignored and must never be committed.
#
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env      (Windows)
#
# Every key is OPTIONAL — the app runs without them, with the matching feature
# disabled. Add only what you need.

# LLM provider keys (any one is enough; the app picks whichever is present) ----
# GitHub Models token — https://github.com/settings/tokens  (github_pat_...)
GITHUB_TOKEN=
# Google Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=

# Optional overrides for the GitHub Models backend ----------------------------
# GITHUB_GPT_MODEL=
# GITHUB_API_URL=

# Discord auto-reply when away (self-bot) -------------------------------------
# Your Discord user token. Leave blank to disable Discord features.
DISCORD_USER_TOKEN=
